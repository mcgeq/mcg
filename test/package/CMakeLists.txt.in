cmake_minimum_required(VERSION 3.25)

project(@PROJECT_NAME@PackageSmokeTest LANGUAGES CXX)

find_package(@PROJECT_NAME@ CONFIG REQUIRED)

add_executable(@mg_package_test_target@ main.cpp)
target_link_libraries(
    @mg_package_test_target@ PRIVATE
    @PROJECT_NAME@::@PROJECT_NAME@
)
target_compile_features(@mg_package_test_target@ PRIVATE cxx_std_23)
set_property(TARGET @mg_package_test_target@ PROPERTY CXX_EXTENSIONS OFF)

if("@mg_enable_cxx_modules@" STREQUAL "ON")
  add_executable(@mg_package_module_test_target@ module_main.cpp)
  set_property(
      TARGET @mg_package_module_test_target@
      PROPERTY
      CXX_SCAN_FOR_MODULES
      ON
  )
  target_link_libraries(
      @mg_package_module_test_target@ PRIVATE
      @PROJECT_NAME@::modules
  )
  target_compile_features(@mg_package_module_test_target@ PRIVATE cxx_std_23)
  set_property(
      TARGET @mg_package_module_test_target@
      PROPERTY
      CXX_EXTENSIONS
      OFF
  )
  if(CMAKE_CXX_COMPILER_ID MATCHES "Clang|GNU")
    target_compile_options(
        @mg_package_module_test_target@
        PRIVATE
        -fstack-protector-strong
    )
  endif()
endif()
