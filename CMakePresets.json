    {
      "name": "developer-mode",
      "hidden": true,
      "cacheVariables": {
        "mg_DEVELOPER_MODE": "ON",
        "VCPKG_MANIFEST_FEATURES": "test"
      }
    },
    {
      "name": "developer-mode-bench",
      "hidden": true,
      "cacheVariables": {
        "mg_DEVELOPER_MODE": "ON",
