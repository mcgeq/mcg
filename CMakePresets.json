      "cacheVariables": {
        "CMAKE_CXX_CPPCHECK": "cppcheck;--inline-suppr",
        "mg_ENABLE_CLANG_TIDY": "ON",
        "mg_CLANG_TIDY_PROFILE": "recommended"
      }
    },
    {
      "name": "analyzers-recommended-gated",
      "hidden": true,
      "cacheVariables": {
        "mg_ENABLE_CLANG_TIDY": "ON",
        "mg_CLANG_TIDY_PROFILE": "recommended",
        "mg_CLANG_TIDY_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "analyzers-strict",
      "hidden": true,
      "cacheVariables": {
        "mg_ENABLE_CLANG_TIDY": "ON",
        "mg_CLANG_TIDY_PROFILE": "strict",
        "mg_CLANG_TIDY_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "modules-enabled",
      "hidden": true,
      "cacheVariables": {
        "mg_ENABLE_CXX_MODULES": "ON"
      }
    },
