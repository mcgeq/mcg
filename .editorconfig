root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cc,cpp,cxx,h,hpp,hxx,ixx,cppm,inl}]
indent_style = space
indent_size = 2

[{CMakeLists.txt,*.cmake,*.json,*.json.in,*.yml,*.yaml}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.{bat,cmd,ps1,sh}]
indent_style = space
indent_size = 4

[*.{md,dox}]
trim_trailing_whitespace = false
